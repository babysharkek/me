---
import Layout from "../Layouts/Layout.astro";
import Background from "../components/background.astro";
---

<Layout title="Games" proxy={true}>
    <nav id="games-topbar">
        <a href="/" id="home-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 17V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M2.352 13.214C1.996 10.916 1.818 9.768 2.252 8.75C2.686 7.731 3.655 7.035 5.591 5.641L7.017 4.6C9.407 2.867 10.602 2 12 2C13.398 2 14.593 2.867 16.983 4.6L18.409 5.641C20.345 7.035 21.314 7.731 21.748 8.75C22.182 9.768 22.004 10.916 21.648 13.214L21.348 15.172C20.847 18.285 20.597 19.841 19.479 20.771C18.361 21.7 16.781 21.7 13.62 21.7H10.38C7.219 21.7 5.639 21.7 4.521 20.771C3.403 19.841 3.153 18.285 2.652 15.172L2.352 13.214Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            Home
        </a>
        <span id="games-topbar-title">Games</span>
    </nav>
    <Background />
    <main id="gmain">
        <div id="gsearch-wrap">
            <form id="gsearch-form" autocomplete="off" onsubmit="return false;">
                <svg id="gsearch-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 21L16.65 16.65M19 11C19 15.4183 15.4183 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <input type="text" id="searchInput" placeholder="search games..." autocomplete="off" />
            </form>
        </div>
        <div id="gtabs">
            <button class="gtab active" data-tab="browse">Browse</button>
            <button class="gtab" data-tab="all">All Games</button>
        </div>
        <div id="categories-content"></div>
        <script src="../scripts/games.ts"></script>
    </main>
</Layout>
