---
import Layout from "../Layouts/Layout.astro";
---

<Layout title="AI">
    <main id="ai-page">
        <!-- Ambient glow -->
        <div id="ai-glow"></div>

        <!-- Sidebar: conversation history -->
        <aside id="ai-sidebar" class="glass-panel">
            <div id="sidebar-header">
                <div id="sidebar-title-row">
                    <span id="sidebar-title">Chats</span>
                    <button
                        id="new-chat-btn"
                        title="New chat"
                        aria-label="New chat"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M12 5V19M5 12H19"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="chat-history">
                <!-- History items injected by ai.ts -->
            </div>
        </aside>

        <!-- Main chat area -->
        <section id="ai-main">
            <!-- Top bar -->
            <header id="ai-header" class="glass-panel">
                <button id="sidebar-toggle" aria-label="Toggle sidebar">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M3 6H21M3 12H21M3 18H21"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"></path>
                    </svg>
                </button>
                <div id="ai-header-info">
                    <div id="ai-model-badge">
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <circle cx="12" cy="12" r="3" fill="currentColor"
                            ></circle>
                            <path
                                d="M12 2V5M12 19V22M2 12H5M19 12H22M4.22 4.22L6.34 6.34M17.66 17.66L19.78 19.78M4.22 19.78L6.34 17.66M17.66 6.34L19.78 4.22"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                        </svg>
                        <span id="model-name">AI Assistant</span>
                    </div>
                </div>
                <div id="header-actions">
                    <button
                        class="header-btn"
                        id="clear-chat-btn"
                        title="Clear chat"
                        aria-label="Clear chat"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M3 6H21M8 6V4H16V6M19 6L18.1 19.1C18.0469 19.9206 17.3777 20.5556 16.555 20.5556H7.445C6.62228 20.5556 5.95313 19.9206 5.9 19.1L5 6"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                    </button>
                </div>
            </header>

            <!-- Messages area -->
            <div id="messages-container">
                <div id="messages">
                    <!-- Welcome state -->
                    <div id="welcome-state">
                        <div id="welcome-icon">
                            <svg
                                width="36"
                                height="36"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <circle
                                    cx="12"
                                    cy="12"
                                    r="3"
                                    fill="currentColor"></circle>
                                <path
                                    d="M12 2V5M12 19V22M2 12H5M19 12H22M4.22 4.22L6.34 6.34M17.66 17.66L19.78 19.78M4.22 19.78L6.34 17.66M17.66 6.34L19.78 4.22"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"></path>
                            </svg>
                        </div>
                        <h1 id="welcome-title">What can I help with?</h1>
                        <p id="welcome-subtitle">
                            Ask me anything — I'm here to assist.
                        </p>
                        <div id="suggestion-chips">
                            <button
                                class="chip"
                                data-prompt="Explain quantum computing simply"
                                >Explain quantum computing</button
                            >
                            <button
                                class="chip"
                                data-prompt="Write a short poem about the ocean"
                                >Write a poem</button
                            >
                            <button
                                class="chip"
                                data-prompt="Help me debug my JavaScript code"
                                >Debug my code</button
                            >
                            <button
                                class="chip"
                                data-prompt="Summarize the history of the internet"
                                >History of the internet</button
                            >
                        </div>
                    </div>
                    <!-- Thinking indicator (moved inside messages) -->
                    <div
                        id="thinking-indicator"
                        class="message assistant"
                        aria-hidden="true"
                    >
                        <div class="message-avatar">
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <circle
                                    cx="12"
                                    cy="12"
                                    r="3"
                                    fill="currentColor"></circle>
                                <path
                                    d="M12 2V5M12 19V22M2 12H5M19 12H22M4.22 4.22L6.34 6.34M17.66 17.66L19.78 19.78M4.22 19.78L6.34 17.66M17.66 6.34L19.78 4.22"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"></path>
                            </svg>
                        </div>
                        <div class="message-body">
                            <div class="message-bubble thinking-bubble">
                                <span class="dot"></span>
                                <span class="dot"></span>
                                <span class="dot"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Input area -->
            <div id="input-wrapper">
                <div id="input-panel" class="glass-panel">
                    <textarea
                        id="chat-input"
                        placeholder="Message AI..."
                        rows="1"
                        aria-label="Message input"></textarea>
                    <div id="input-actions">
                        <button
                            id="send-btn"
                            aria-label="Send message"
                            disabled
                        >
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M12 19V5M5 12L12 5L19 12"
                                    stroke="currentColor"
                                    stroke-width="2.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </button>
                    </div>
                </div>
                <p id="input-disclaimer">
                    AI can make mistakes. Verify important information.
                </p>
            </div>
        </section>
    </main>

    <script src="../scripts/ai.ts"></script>
</Layout>
