---
import Layout from "../Layouts/Layout.astro";
import Background from "../components/background.astro";
---

<Layout title="Bolt Proxy" proxy={false}>
    <Background />
    <main id="home-main">
        <div id="home-center">
            <h1 id="main-title">Bolt proxy</h1>
            <p id="tagline">to all F-Students: have fun guys keep failing school ily all</p>

            <div id="search-wrap">
                <form id="search-form" method="GET" action="javascript:void(0)">
                    <svg id="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21L15.0001 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" name="q" id="search-input" placeholder="search anything..." autocomplete="off" />
                </form>
                <div id="suggestions"></div>
            </div>

            <div id="stats-row">
                <span id="stat-online"><span id="online-count">—</span> online</span>
                <span class="stat-dot">·</span>
                <span id="stat-visits"><span id="visits-count">—</span> total visits</span>
            </div>

            <div id="discord-section">
                <p id="discord-label">JOIN OUR DISCORD FOR MORE LINKS</p>
                <a id="discord-link" href="https://discord.gg/bolt" target="_blank" rel="noopener">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.101 18.08.114 18.102.133 18.115a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                    </svg>
                    Discord
                </a>
            </div>
        </div>

        <!-- Devices Panel (popup) -->
        <div id="devices-panel" style="display:none">
            <p class="devices-panel-title">Devices on your key</p>
            <ul id="devices-list"></ul>
        </div>

        <!-- Bottom Nav -->
        <nav id="bottom-nav">
            <a href="/" class="nav-btn active">Home</a>
            <a href="/games" class="nav-btn">Games</a>
            <button id="devices-btn" class="nav-btn" style="display:none">
                <span id="device-dots"></span>
                <span id="devices-label">Devices</span>
            </button>
            <a href="/settings" class="nav-btn">Settings</a>
        </nav>
    </main>

    <script is:inline>
        (function() {
            // Animate visit counter
            function animateCount(el, target, suffix) {
                var start = 0;
                var duration = 1200;
                var startTime = null;
                function step(ts) {
                    if (!startTime) startTime = ts;
                    var progress = Math.min((ts - startTime) / duration, 1);
                    var val = Math.floor(progress * target);
                    el.textContent = val.toLocaleString() + (suffix || '');
                    if (progress < 1) requestAnimationFrame(step);
                    else el.textContent = target.toLocaleString() + (suffix || '');
                }
                requestAnimationFrame(step);
            }

            // Show static/simulated stats
            var onlineEl = document.getElementById('online-count');
            var visitsEl = document.getElementById('visits-count');
            if (onlineEl) animateCount(onlineEl, Math.floor(Math.random() * 200) + 150, '');
            if (visitsEl) animateCount(visitsEl, 1264332, '');

            // Device info
            fetch('/api/me').then(function(r) { return r.json(); }).then(function(data) {
                var btn = document.getElementById('devices-btn');
                var dotsEl = document.getElementById('device-dots');
                var list = document.getElementById('devices-list');
                var panel = document.getElementById('devices-panel');
                if (!btn || !dotsEl || !list || !panel) return;

                var dots = '';
                for (var i = 1; i <= data.maxDevices; i++) {
                    if (i === data.currentDevice) {
                        dots += '<span class="dot dot-you" title="Device ' + i + ' (you)"></span>';
                    } else if (i <= data.totalDevices) {
                        dots += '<span class="dot dot-active" title="Device ' + i + '"></span>';
                    } else {
                        dots += '<span class="dot dot-empty" title="Open slot"></span>';
                    }
                }
                dotsEl.innerHTML = dots;
                btn.style.display = 'flex';

                var items = '';
                for (var j = 1; j <= data.maxDevices; j++) {
                    if (j === data.currentDevice) {
                        items += '<li class="device-item device-you"><span class="device-dot dot-you"></span>Device ' + j + '<span class="device-tag">you</span></li>';
                    } else if (j <= data.totalDevices) {
                        items += '<li class="device-item device-taken"><span class="device-dot dot-active"></span>Device ' + j + '<span class="device-tag device-tag-taken">connected</span></li>';
                    } else {
                        items += '<li class="device-item device-open"><span class="device-dot dot-empty"></span>Open slot</li>';
                    }
                }
                list.innerHTML = items;

                var open = false;
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    open = !open;
                    panel.style.display = open ? 'block' : 'none';
                });
                document.addEventListener('click', function() {
                    if (open) { open = false; panel.style.display = 'none'; }
                });
                panel.addEventListener('click', function(e) { e.stopPropagation(); });
            }).catch(function() {});
        })();
    </script>
    <script src="../scripts/index.ts"></script>
    <script src="../scripts/global.ts"></script>
</Layout>

<style>
    #home-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-bottom: 100px;
    }

    #home-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        width: 100%;
        max-width: 680px;
        padding: 0 20px;
    }

    #main-title {
        font-size: clamp(3.5rem, 10vw, 6.5rem);
        font-family: bold;
        color: #fff;
        margin: 0 0 0.5rem 0;
        line-height: 1;
        letter-spacing: -0.02em;
        text-align: center;
    }

    #tagline {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.45);
        font-family: medium;
        margin: 0 0 2.2rem 0;
        text-align: center;
        letter-spacing: 0.01em;
    }

    #search-wrap {
        width: 100%;
        background: rgba(255,255,255,0.07);
        border-radius: 50px;
        padding: 14px 20px;
        margin-bottom: 1.4rem;
        position: relative;
    }

    #search-form {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    #search-icon {
        color: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    #search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-size: 1rem;
        font-family: medium;
    }

    #search-input::placeholder {
        color: rgba(255,255,255,0.3);
    }

    #suggestions {
        display: none;
        flex-direction: column;
        margin-top: 10px;
        gap: 2px;
    }

    #suggestions.open {
        display: flex;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 6px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        font-family: medium;
        border: none;
        background: transparent;
        text-align: left;
        width: 100%;
    }

    .suggestion-item:hover,
    .suggestion-item.active {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

    .suggestion-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .suggestion-label {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .suggestion-hint {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    #stats-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.4);
        font-family: medium;
        margin-bottom: 1.4rem;
    }

    #stats-row #online-count {
        color: #fff;
        font-family: bold;
    }

    #stats-row #visits-count {
        color: #fff;
        font-family: bold;
    }

    .stat-dot {
        opacity: 0.3;
    }

    #discord-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    #discord-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        margin: 0;
        text-transform: uppercase;
    }

    #discord-link {
        display: flex;
        align-items: center;
        gap: 7px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        font-family: medium;
        padding: 6px 14px;
        border-radius: 100px;
        transition: color 0.2s, background 0.2s;
    }

    #discord-link:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
    }

    /* Devices panel */
    #devices-panel {
        position: fixed;
        bottom: 90px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(18,18,24,0.96);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 18px;
        padding: 16px 18px;
        min-width: 220px;
        z-index: 300;
        box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    }

    .devices-panel-title {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.35);
        font-family: medium;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        margin: 0 0 12px 0;
    }

    #devices-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .device-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.87rem;
        font-family: medium;
        padding: 4px 2px;
    }

    .device-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .device-you { color: #fff; }
    .device-taken { color: rgba(255,255,255,0.55); }
    .device-open { color: rgba(255,255,255,0.25); font-style: italic; }

    .device-tag {
        margin-left: auto;
        font-size: 0.68rem;
        background: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.6);
        padding: 2px 8px;
        border-radius: 100px;
        font-family: medium;
    }

    .device-tag-taken {
        background: rgba(255,165,0,0.15);
        color: rgba(255,165,0,0.8);
    }

    /* Bottom Nav */
    #bottom-nav {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(22,22,28,0.88);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 50px;
        padding: 6px 8px;
        z-index: 200;
        box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }

    .nav-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 38px;
        padding: 0 18px;
        border-radius: 50px;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.45);
        cursor: pointer;
        text-decoration: none;
        font-family: medium;
        font-size: 0.88rem;
        transition: color 0.2s ease, background 0.2s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .nav-btn:hover {
        color: rgba(255,255,255,0.9);
        background: rgba(255,255,255,0.08);
    }

    .nav-btn.active {
        color: #fff;
        background: rgba(255,255,255,0.1);
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

    .dot-you {
        background: #fff;
    }

    .dot-active {
        background: rgba(255,165,0,0.85);
    }

    .dot-empty {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.2);
    }

    #device-dots {
        display: flex;
        align-items: center;
        gap: 3px;
    }
</style>
