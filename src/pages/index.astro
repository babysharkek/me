---
import Layout from "../Layouts/Layout.astro";
import Background from "../components/background.astro";
---

<Layout title="Bolt Proxy" proxy={false}>
    <Background />
    <main id="home-main">
        <div id="home-center">
            <h1 id="main-title">Bolt proxy</h1>
            <p id="tagline">to all F-Students: have fun guys keep failing school ily all</p>

            <div id="search-wrap">
                <form id="search-form" method="GET" action="javascript:void(0)">
                    <svg id="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21L15.0001 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" name="q" id="search-input" placeholder="search anything..." autocomplete="off" />
                </form>
            </div>

            <div id="quick-links">
                <button class="quick-link" data-url="https://youtube.com">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="color:#ff0000">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    <span>YouTube</span>
                </button>
                <button class="quick-link" data-url="https://tiktok.com">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                    </svg>
                    <span>TikTok</span>
                </button>
                <button class="quick-link" data-url="https://gemini.google.com">
                    <img src="/icons/gemini.svg" alt="Gemini" class="ql-img" />
                    <span>Gemini</span>
                </button>
                <button class="quick-link" data-url="https://flixbaba.mov">
                    <img src="/icons/flixbaba.ico" alt="FlixBaba" class="ql-img" />
                    <span>FlixBaba</span>
                </button>
                <button class="quick-link" data-url="https://justanime.to">
                    <img src="https://www.google.com/s2/favicons?domain=justanime.to&sz=64" alt="JustAnime" class="ql-img" />
                    <span>JustAnime</span>
                </button>
                <button class="quick-link" data-url="https://cinekada.com">
                    <img src="/icons/cinekada.ico" alt="CineKada" class="ql-img" />
                    <span>CineKada</span>
                </button>
                <button class="quick-link" data-url="https://footballia.eu">
                    <img src="https://www.google.com/s2/favicons?domain=footballia.eu&sz=64" alt="Footballia" class="ql-img" />
                    <span>Footballia</span>
                </button>
            </div>
        </div>

        <!-- Devices Panel (popup) -->
        <div id="devices-panel" style="display:none">
            <p class="devices-panel-title">Devices on your key</p>
            <ul id="devices-list"></ul>
        </div>

        <!-- Bottom Nav -->
        <nav id="bottom-nav">
            <a href="/" class="nav-btn active">Home</a>
            <a href="/games" class="nav-btn">Games</a>
            <button id="devices-btn" class="nav-btn" style="display:none">
                <span id="device-dots"></span>
                <span id="devices-label">Devices</span>
            </button>
            <a href="/settings" class="nav-btn">Settings</a>
        </nav>
    </main>

    <script is:inline>
        (function() {
            // Device info
            fetch('/api/me').then(function(r) { return r.json(); }).then(function(data) {
                var btn = document.getElementById('devices-btn');
                var dotsEl = document.getElementById('device-dots');
                var list = document.getElementById('devices-list');
                var panel = document.getElementById('devices-panel');
                if (!btn || !dotsEl || !list || !panel) return;

                var dots = '';
                for (var i = 1; i <= data.maxDevices; i++) {
                    if (i === data.currentDevice) {
                        dots += '<span class="dot dot-you" title="Device ' + i + ' (you)"></span>';
                    } else if (i <= data.totalDevices) {
                        dots += '<span class="dot dot-active" title="Device ' + i + '"></span>';
                    } else {
                        dots += '<span class="dot dot-empty" title="Open slot"></span>';
                    }
                }
                dotsEl.innerHTML = dots;
                btn.style.display = 'flex';

                var items = '';
                for (var j = 1; j <= data.maxDevices; j++) {
                    if (j === data.currentDevice) {
                        items += '<li class="device-item device-you"><span class="device-dot dot-you"></span>Device ' + j + '<span class="device-tag">you</span></li>';
                    } else if (j <= data.totalDevices) {
                        items += '<li class="device-item device-taken"><span class="device-dot dot-active"></span>Device ' + j + '<span class="device-tag device-tag-taken">connected</span></li>';
                    } else {
                        items += '<li class="device-item device-open"><span class="device-dot dot-empty"></span>Open slot</li>';
                    }
                }
                list.innerHTML = items;

                var open = false;
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    open = !open;
                    panel.style.display = open ? 'block' : 'none';
                });
                document.addEventListener('click', function() {
                    if (open) { open = false; panel.style.display = 'none'; }
                });
                panel.addEventListener('click', function(e) { e.stopPropagation(); });
            }).catch(function() {});
        })();
    </script>
    <script src="../scripts/index.ts"></script>
    <script src="../scripts/global.ts"></script>
</Layout>

<style>
    #home-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-bottom: 100px;
    }

    #home-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        width: 100%;
        max-width: 680px;
        padding: 0 20px;
    }

    #main-title {
        font-size: clamp(3.5rem, 10vw, 6.5rem);
        font-family: bold;
        color: #fff;
        margin: 0 0 0.5rem 0;
        line-height: 1;
        letter-spacing: -0.02em;
        text-align: center;
    }

    #tagline {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.45);
        font-family: medium;
        margin: 0 0 2.2rem 0;
        text-align: center;
        letter-spacing: 0.01em;
    }

    #search-wrap {
        width: 100%;
        background: rgba(255,255,255,0.07);
        border-radius: 50px;
        padding: 14px 20px;
        margin-bottom: 1rem;
    }

    #quick-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        width: 100%;
        margin-bottom: 0;
    }

    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        min-width: 80px;
        max-width: 106px;
        height: 72px;
        border-radius: 14px;
        padding: 10px 6px;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.05);
        color: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        gap: 5px;
    }

    .quick-link:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.15);
        transform: translateY(-2px);
    }

    .quick-link svg {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
    }

    .ql-img {
        width: 26px;
        height: 26px;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 5px;
    }

    .quick-link span {
        font-size: 0.72rem;
        font-family: medium;
        color: rgba(255,255,255,0.7);
    }

    #search-form {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    #search-icon {
        color: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    #search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-size: 1rem;
        font-family: medium;
    }

    #search-input::placeholder {
        color: rgba(255,255,255,0.3);
    }

    #suggestions {
        display: none;
        flex-direction: column;
        margin-top: 10px;
        gap: 2px;
    }

    #suggestions.open {
        display: flex;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 6px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        font-family: medium;
        border: none;
        background: transparent;
        text-align: left;
        width: 100%;
    }

    .suggestion-item:hover,
    .suggestion-item.active {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

    .suggestion-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .suggestion-label {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .suggestion-hint {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    #stats-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.4);
        font-family: medium;
        margin-bottom: 1.4rem;
    }

    #stats-row #online-count {
        color: #fff;
        font-family: bold;
    }

    #stats-row #visits-count {
        color: #fff;
        font-family: bold;
    }

    .stat-dot {
        opacity: 0.3;
    }

    #discord-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    #discord-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        margin: 0;
        text-transform: uppercase;
    }

    #discord-link {
        display: flex;
        align-items: center;
        gap: 7px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        font-family: medium;
        padding: 6px 14px;
        border-radius: 100px;
        transition: color 0.2s, background 0.2s;
    }

    #discord-link:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
    }

    /* Devices panel */
    #devices-panel {
        position: fixed;
        bottom: 90px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(18,18,24,0.96);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 18px;
        padding: 16px 18px;
        min-width: 220px;
        z-index: 300;
        box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    }

    .devices-panel-title {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.35);
        font-family: medium;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        margin: 0 0 12px 0;
    }

    #devices-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .device-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.87rem;
        font-family: medium;
        padding: 4px 2px;
    }

    .device-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .device-you { color: #fff; }
    .device-taken { color: rgba(255,255,255,0.55); }
    .device-open { color: rgba(255,255,255,0.25); font-style: italic; }

    .device-tag {
        margin-left: auto;
        font-size: 0.68rem;
        background: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.6);
        padding: 2px 8px;
        border-radius: 100px;
        font-family: medium;
    }

    .device-tag-taken {
        background: rgba(255,165,0,0.15);
        color: rgba(255,165,0,0.8);
    }

    /* Bottom Nav */
    #bottom-nav {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(22,22,28,0.88);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 50px;
        padding: 6px 8px;
        z-index: 200;
        box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }

    .nav-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 38px;
        padding: 0 18px;
        border-radius: 50px;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.45);
        cursor: pointer;
        text-decoration: none;
        font-family: medium;
        font-size: 0.88rem;
        transition: color 0.2s ease, background 0.2s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .nav-btn:hover {
        color: rgba(255,255,255,0.9);
        background: rgba(255,255,255,0.08);
    }

    .nav-btn.active {
        color: #fff;
        background: rgba(255,255,255,0.1);
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

    .dot-you {
        background: #fff;
    }

    .dot-active {
        background: rgba(255,165,0,0.85);
    }

    .dot-empty {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.2);
    }

    #device-dots {
        display: flex;
        align-items: center;
        gap: 3px;
    }
</style>
