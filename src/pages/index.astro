---
import Layout from "../Layouts/Layout.astro";
import Background from "../components/background.astro";
---

<Layout title="Bolt Proxy" proxy={false}>
    <Background />
    <main id="home-main">
        <div id="home-center">
            <h1 id="main-title">Bolt proxy</h1>

            <div id="search-wrap">
                <form id="search-form" method="GET" action="javascript:void(0)">
                    <svg id="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21L15.0001 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" name="q" id="search-input" placeholder="search anything..." autocomplete="off" />
                </form>
            </div>

            <div id="quick-links">
                <button class="quick-link" data-url="https://youtube.com">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="color:#ff0000">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    <span>YouTube</span>
                </button>
                <button class="quick-link" data-url="https://tiktok.com">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                    </svg>
                    <span>TikTok</span>
                </button>
                <button class="quick-link" data-url="https://gemini.google.com">
                    <img src="/icons/gemini.svg" alt="Gemini" class="ql-img" />
                    <span>Gemini</span>
                </button>
                <button class="quick-link" data-url="https://flixbaba.mov">
                    <img src="/icons/flixbaba.ico" alt="FlixBaba" class="ql-img" />
                    <span>FlixBaba</span>
                </button>
                <button class="quick-link" data-url="https://justanime.to">
                    <img src="https://www.google.com/s2/favicons?domain=justanime.to&sz=64" alt="JustAnime" class="ql-img" />
                    <span>JustAnime</span>
                </button>
                <button class="quick-link" data-url="https://cinekada.com">
                    <img src="/icons/cinekada.ico" alt="CineKada" class="ql-img" />
                    <span>CineKada</span>
                </button>
                <button class="quick-link" data-url="https://footballia.eu">
                    <img src="https://www.google.com/s2/favicons?domain=footballia.eu&sz=64" alt="Footballia" class="ql-img" />
                    <span>Footballia</span>
                </button>
            </div>
        </div>

        <!-- Devices Panel (popup) -->
        <div id="devices-panel" style="display:none">
            <p class="devices-panel-title">Devices on your key</p>
            <ul id="devices-list"></ul>
            <div id="devices-footer">
                <button id="logout-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Log out this device
                </button>
            </div>
        </div>

        <!-- Bottom Nav -->
        <nav id="bottom-nav">
            <a href="/" class="nav-btn active">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 17V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M2.352 13.214C1.996 10.916 1.818 9.768 2.252 8.75C2.686 7.731 3.655 7.035 5.591 5.641L7.017 4.6C9.407 2.867 10.602 2 12 2C13.398 2 14.593 2.867 16.983 4.6L18.409 5.641C20.345 7.035 21.314 7.731 21.748 8.75C22.182 9.768 22.004 10.916 21.648 13.214L21.348 15.172C20.847 18.285 20.597 19.841 19.479 20.771C18.361 21.7 16.781 21.7 13.62 21.7H10.38C7.219 21.7 5.639 21.7 4.521 20.771C3.403 19.841 3.153 18.285 2.652 15.172L2.352 13.214Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                Home
            </a>
            <a href="/games" class="nav-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12H8M7 11V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15.5 12H16.5M17.5 12H18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M11 8C9.89 8 8.82 8.26 7.87 8.73C6.35 9.49 5.11 10.77 4.42 12.35C3.73 13.93 3.62 15.71 4.12 17.37C4.62 19.03 5.69 20.46 7.13 21.41C8.57 22.36 10.28 22.76 11.98 22.56L12 19.5L12.02 22.56C13.72 22.76 15.43 22.36 16.87 21.41C18.31 20.46 19.38 19.03 19.88 17.37C20.38 15.71 20.27 13.93 19.58 12.35C18.89 10.77 17.65 9.49 16.13 8.73C15.18 8.26 14.11 8 13 8H11Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 8V6.5C9 5.12 10.12 4 11.5 4H12.5C13.88 4 15 5.12 15 6.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Games
            </a>
            <button id="devices-btn" class="nav-btn" style="display:none">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 12C2 8.229 2 6.343 3.172 5.172C4.343 4 6.229 4 10 4H14C17.771 4 19.657 4 20.828 5.172C22 6.343 22 8.229 22 12V13C22 16.771 22 18.657 20.828 19.828C19.657 21 17.771 21 14 21H10C6.229 21 4.343 21 3.172 19.828C2 18.657 2 16.771 2 13V12Z" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M12 17H12.009" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 21L7.5 22M16 21L16.5 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M6 22H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span id="device-dots"></span>
                <span id="devices-label">Devices</span>
            </button>
        </nav>

        <!-- Panic key hint -->
        <p id="panic-hint">Press <kbd>\</kbd> to panic</p>
    </main>

    <script is:inline>
        (function() {
            // Parse a user-agent string into a friendly device name
            function deviceName(ua) {
                if (!ua) return 'Unknown Device';
                if (/iPhone/.test(ua)) return 'iPhone';
                if (/iPad/.test(ua)) return 'iPad';
                if (/CrOS/.test(ua)) return 'Chromebook';
                if (/Android/.test(ua)) {
                    var m = ua.match(/Android [^;]+; ([^)]+)\)/);
                    return m ? m[1].trim() : 'Android Device';
                }
                if (/Windows NT 10/.test(ua)) return 'Windows 10/11 PC';
                if (/Windows NT 6/.test(ua)) return 'Windows PC';
                if (/Macintosh/.test(ua)) return 'Mac';
                if (/Linux/.test(ua)) return 'Linux PC';
                return 'Unknown Device';
            }

            // Device icon SVG per type
            function deviceIcon(ua) {
                var mobile = /iPhone|iPad|Android/.test(ua || '');
                if (mobile) return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>';
                return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>';
            }

            function loadDevices() {
                fetch('/api/me').then(function(r) { return r.json(); }).then(function(data) {
                    var btn = document.getElementById('devices-btn');
                    var dotsEl = document.getElementById('device-dots');
                    var list = document.getElementById('devices-list');
                    var panel = document.getElementById('devices-panel');
                    var logoutBtn = document.getElementById('logout-btn');
                    if (!btn || !dotsEl || !list || !panel) return;

                    // Dots indicator
                    var dots = '';
                    for (var i = 1; i <= data.maxDevices; i++) {
                        var dev = data.devices && data.devices.find(function(d) { return d.index === i; });
                        if (dev && dev.isCurrent) {
                            dots += '<span class="dot dot-you" title="You"></span>';
                        } else if (dev) {
                            dots += '<span class="dot dot-active" title="Connected"></span>';
                        } else {
                            dots += '<span class="dot dot-empty" title="Open slot"></span>';
                        }
                    }
                    dotsEl.innerHTML = dots;
                    btn.style.display = 'flex';

                    // Device list
                    var html = '';
                    for (var j = 1; j <= data.maxDevices; j++) {
                        var d = data.devices && data.devices.find(function(x) { return x.index === j; });
                        if (d && d.isCurrent) {
                            html += '<li class="device-item device-you">'
                                + '<span class="device-status-dot dot-you"></span>'
                                + '<span class="device-icon">' + deviceIcon(d.ua) + '</span>'
                                + '<span class="device-name">' + deviceName(d.ua) + '</span>'
                                + '<span class="device-tag">you</span>'
                                + '<button class="kick-btn kick-self">Log out</button>'
                                + '</li>';
                        } else if (d) {
                            html += '<li class="device-item device-taken">'
                                + '<span class="device-status-dot dot-active"></span>'
                                + '<span class="device-icon">' + deviceIcon(d.ua) + '</span>'
                                + '<span class="device-name">' + deviceName(d.ua) + '</span>'
                                + '<button class="kick-btn" data-idx="' + d.index + '">Remove</button>'
                                + '</li>';
                        } else {
                            html += '<li class="device-item device-open">'
                                + '<span class="device-status-dot dot-empty"></span>'
                                + '<span class="device-name open-slot">Open slot</span>'
                                + '</li>';
                        }
                    }
                    list.innerHTML = html;

                    // Self logout buttons
                    list.querySelectorAll('.kick-self').forEach(function(b) {
                        b.addEventListener('click', function(e) {
                            e.stopPropagation();
                            if (!confirm('Log out this device?')) return;
                            fetch('/api/logout', { method: 'POST' }).then(function() {
                                window.location.href = '/login';
                            });
                        });
                    });

                    // Kick other device buttons
                    list.querySelectorAll('.kick-btn:not(.kick-self)').forEach(function(b) {
                        b.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var idx = parseInt(b.getAttribute('data-idx'));
                            b.textContent = '...';
                            b.disabled = true;
                            fetch('/api/kick-device', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ deviceIndex: idx })
                            }).then(function() { loadDevices(); }).catch(function() { b.textContent = 'Remove'; b.disabled = false; });
                        });
                    });

                    // Legacy footer logout (hidden but keep wired)
                    if (logoutBtn) {
                        logoutBtn.onclick = function() {
                            fetch('/api/logout', { method: 'POST' }).then(function() {
                                window.location.href = '/login';
                            });
                        };
                    }

                    var open = false;
                    btn.onclick = null;
                    btn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        open = !open;
                        panel.style.display = open ? 'block' : 'none';
                    });
                    document.addEventListener('click', function() {
                        if (open) { open = false; panel.style.display = 'none'; }
                    });
                    panel.addEventListener('click', function(e) { e.stopPropagation(); });
                }).catch(function() {});
            }

            loadDevices();

            // Panic key: backslash → redirect to safe page
            document.addEventListener('keydown', function(e) {
                if (e.key === '\\' || e.key === 'Backslash') {
                    window.location.href = 'https://classroom.google.com';
                }
            });
        })();
    </script>
    <script src="../scripts/index.ts"></script>
    <script src="../scripts/global.ts"></script>
</Layout>

<style>
    #home-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-bottom: 100px;
    }

    #home-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        width: 100%;
        max-width: 680px;
        padding: 0 20px;
    }

    #main-title {
        font-size: clamp(3.5rem, 10vw, 6.5rem);
        font-family: bold;
        color: #fff;
        margin: 0 0 0.5rem 0;
        line-height: 1;
        letter-spacing: -0.02em;
        text-align: center;
    }

    #tagline {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.45);
        font-family: medium;
        margin: 0 0 2.2rem 0;
        text-align: center;
        letter-spacing: 0.01em;
    }

    #search-wrap {
        width: 100%;
        background: rgba(255,255,255,0.07);
        border-radius: 50px;
        padding: 14px 20px;
        margin-bottom: 1rem;
    }

    #quick-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        width: 100%;
        margin-bottom: 0;
    }

    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        min-width: 80px;
        max-width: 106px;
        height: 72px;
        border-radius: 14px;
        padding: 10px 6px;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.05);
        color: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        gap: 5px;
    }

    .quick-link:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.15);
        transform: translateY(-2px);
    }

    .quick-link svg {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
    }

    .ql-img {
        width: 26px;
        height: 26px;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 5px;
    }

    .quick-link span {
        font-size: 0.72rem;
        font-family: medium;
        color: rgba(255,255,255,0.7);
    }

    #search-form {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    #search-icon {
        color: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    #search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-size: 1rem;
        font-family: medium;
    }

    #search-input::placeholder {
        color: rgba(255,255,255,0.3);
    }

    #suggestions {
        display: none;
        flex-direction: column;
        margin-top: 10px;
        gap: 2px;
    }

    #suggestions.open {
        display: flex;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 6px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        font-family: medium;
        border: none;
        background: transparent;
        text-align: left;
        width: 100%;
    }

    .suggestion-item:hover,
    .suggestion-item.active {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

    .suggestion-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .suggestion-label {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .suggestion-hint {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    #stats-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.4);
        font-family: medium;
        margin-bottom: 1.4rem;
    }

    #stats-row #online-count {
        color: #fff;
        font-family: bold;
    }

    #stats-row #visits-count {
        color: #fff;
        font-family: bold;
    }

    .stat-dot {
        opacity: 0.3;
    }

    #discord-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    #discord-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        margin: 0;
        text-transform: uppercase;
    }

    #discord-link {
        display: flex;
        align-items: center;
        gap: 7px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        font-family: medium;
        padding: 6px 14px;
        border-radius: 100px;
        transition: color 0.2s, background 0.2s;
    }

    #discord-link:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
    }

    /* Devices panel */
    #devices-panel {
        position: fixed;
        bottom: 90px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(14,14,20,0.97);
        backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 18px 18px 14px;
        min-width: 260px;
        z-index: 300;
        box-shadow: 0 12px 50px rgba(0,0,0,0.6);
        color: #fff;
    }

    .devices-panel-title {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0 0 14px 0;
    }

    #devices-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .device-item {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 0.85rem;
        font-family: medium;
        padding: 8px 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
        color: #fff !important;
    }

    .device-you { background: rgba(255,255,255,0.07); }
    .device-taken { }
    .device-open { color: rgba(255,255,255,0.45) !important; }

    .device-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .device-icon {
        display: flex;
        align-items: center;
        opacity: 0.6;
        flex-shrink: 0;
    }

    .device-name {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .open-slot { font-style: italic; font-size: 0.8rem; }

    .device-tag {
        font-size: 0.65rem;
        background: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.5);
        padding: 2px 8px;
        border-radius: 100px;
        font-family: medium;
        flex-shrink: 0;
    }

    .kick-btn {
        margin-left: auto;
        flex-shrink: 0;
        font-size: 0.68rem;
        background: rgba(255,80,80,0.12);
        color: rgba(255,100,100,0.9);
        border: 1px solid rgba(255,80,80,0.2);
        padding: 3px 10px;
        border-radius: 100px;
        cursor: pointer;
        font-family: medium;
        transition: background 0.15s;
    }

    .kick-btn:hover { background: rgba(255,80,80,0.22); }
    .kick-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    #devices-footer {
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px solid rgba(255,255,255,0.07);
    }

    #logout-btn {
        display: flex;
        align-items: center;
        gap: 7px;
        width: 100%;
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.4);
        font-size: 0.8rem;
        font-family: medium;
        cursor: pointer;
        padding: 4px 2px;
        border-radius: 6px;
        transition: color 0.15s;
    }

    #logout-btn:hover { color: rgba(255,100,100,0.9); }

    /* Panic hint */
    #panic-hint {
        position: fixed;
        bottom: 22px;
        right: 22px;
        font-size: 0.7rem;
        color: rgba(255,255,255,0.18);
        font-family: medium;
        margin: 0;
        pointer-events: none;
        z-index: 100;
    }

    #panic-hint kbd {
        display: inline-block;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 4px;
        padding: 1px 5px;
        font-family: monospace;
        font-size: 0.72rem;
    }

    /* Bottom Nav */
    #bottom-nav {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(22,22,28,0.88);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 50px;
        padding: 6px 8px;
        z-index: 200;
        box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }

    .nav-btn {
