---
import Layout from "../Layouts/Layout.astro";
import Background from "../components/background.astro";
---

<Layout title="Bolt Proxy" proxy={false}>
    <Background />
    <main id="home-main">
        <div id="home-center">
            <h1 id="main-title">Bolt proxy</h1>

            <div id="search-wrap">
                <form id="search-form" method="GET" action="javascript:void(0)">
                    <svg id="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21L15.0001 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" name="q" id="search-input" placeholder="search anything..." autocomplete="off" />
                </form>
            </div>

            <div id="quick-links">
                <button class="quick-link" data-url="https://youtube.com">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="color:#ff0000">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    <span>YouTube</span>
                </button>
                <button class="quick-link" data-url="https://tiktok.com">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                    </svg>
                    <span>TikTok</span>
                </button>
                <button class="quick-link" data-url="https://gemini.google.com">
                    <img src="/icons/gemini.svg" alt="Gemini" class="ql-img" />
                    <span>Gemini</span>
                </button>
                <button class="quick-link" data-url="https://flixbaba.mov">
                    <img src="/icons/flixbaba.ico" alt="FlixBaba" class="ql-img" />
                    <span>FlixBaba</span>
                </button>
                <button class="quick-link" data-url="https://justanime.to">
                    <img src="https://www.google.com/s2/favicons?domain=justanime.to&sz=64" alt="JustAnime" class="ql-img" />
                    <span>JustAnime</span>
                </button>
                <button class="quick-link" data-url="https://cinekada.com">
                    <img src="/icons/cinekada.ico" alt="CineKada" class="ql-img" />
                    <span>CineKada</span>
                </button>
                <button class="quick-link" data-url="https://footballia.eu">
                    <img src="https://www.google.com/s2/favicons?domain=footballia.eu&sz=64" alt="Footballia" class="ql-img" />
                    <span>Footballia</span>
                </button>
                <button class="quick-link" data-url="https://discord.com">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="color:#5865F2">
                        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                    </svg>
                    <span>Discord</span>
                </button>
                <button class="quick-link" data-url="https://now.gg">
                    <img src="https://www.google.com/s2/favicons?domain=now.gg&sz=64" alt="now.gg" class="ql-img" />
                    <span>now.gg</span>
                </button>
            </div>
        </div>

        <!-- Devices Panel (popup) -->
        <div id="devices-panel" style="display:none">
            <p class="devices-panel-title">Devices on your key</p>
            <ul id="devices-list"></ul>
        </div>

        <!-- Custom Sign-out Confirm Modal -->
        <div id="signout-modal" style="display:none">
            <div id="signout-modal-box">
                <div id="signout-modal-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </div>
                <p id="signout-modal-title">Sign out this device?</p>
                <p id="signout-modal-desc">You'll need your access key to log back in.</p>
                <div id="signout-modal-actions">
                    <button id="signout-cancel">Cancel</button>
                    <button id="signout-confirm">Sign out</button>
                </div>
            </div>
        </div>

        <!-- Bottom Nav -->
        <nav id="bottom-nav">
            <a href="/" class="nav-btn active">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 17V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M2.352 13.214C1.996 10.916 1.818 9.768 2.252 8.75C2.686 7.731 3.655 7.035 5.591 5.641L7.017 4.6C9.407 2.867 10.602 2 12 2C13.398 2 14.593 2.867 16.983 4.6L18.409 5.641C20.345 7.035 21.314 7.731 21.748 8.75C22.182 9.768 22.004 10.916 21.648 13.214L21.348 15.172C20.847 18.285 20.597 19.841 19.479 20.771C18.361 21.7 16.781 21.7 13.62 21.7H10.38C7.219 21.7 5.639 21.7 4.521 20.771C3.403 19.841 3.153 18.285 2.652 15.172L2.352 13.214Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                Home
            </a>
            <a href="/games" class="nav-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 10H16M15 9V11M6.5 10.5H8M7.5 9.5V11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2.524 14.622C3.452 17.893 6.19 22 9.433 22C11.68 22 12.32 20.5 12 19C11.93 18.68 12.21 18 12.5 18C12.79 18 13.07 18.68 13 19C12.68 20.5 13.32 22 15.567 22C18.81 22 21.548 17.893 22.476 14.622C23.562 10.891 22.318 7 18.5 7H5.5C1.682 7 0.438 10.891 2.524 14.622Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                Games
            </a>
            <button id="devices-btn" class="nav-btn" style="display:none">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 12C2 8.229 2 6.343 3.172 5.172C4.343 4 6.229 4 10 4H14C17.771 4 19.657 4 20.828 5.172C22 6.343 22 8.229 22 12V13C22 16.771 22 18.657 20.828 19.828C19.657 21 17.771 21 14 21H10C6.229 21 4.343 21 3.172 19.828C2 18.657 2 16.771 2 13V12Z" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M12 17H12.009" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 21L7.5 22M16 21L16.5 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M6 22H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span id="device-dots"></span>
                <span id="devices-label">Devices</span>
            </button>
        </nav>

        <!-- Panic key hint -->
        <p id="panic-hint">Press <kbd>\</kbd> to panic</p>
    </main>

    <script is:inline>
        (function() {
            // Parse a user-agent string into a friendly device name
            function deviceName(ua) {
                if (!ua) return 'Unknown Device';
                if (/iPhone/.test(ua)) return 'iPhone';
                if (/iPad/.test(ua)) return 'iPad';
                if (/CrOS/.test(ua)) return 'Chromebook';
                if (/Android/.test(ua)) {
                    var m = ua.match(/Android [^;]+; ([^)]+)\)/);
                    return m ? m[1].trim() : 'Android Device';
                }
                if (/Windows NT 10/.test(ua)) return 'Windows 10/11 PC';
                if (/Windows NT 6/.test(ua)) return 'Windows PC';
                if (/Macintosh/.test(ua)) return 'Mac';
                if (/Linux/.test(ua)) return 'Linux PC';
                return 'Unknown Device';
            }

            // Device icon SVG per type (Hugeicons smartphone style)
            function deviceIcon(ua) {
                return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9C5 6.172 5 4.757 5.879 3.879C6.757 3 8.172 3 11 3H13C15.828 3 17.243 3 18.121 3.879C19 4.757 19 6.172 19 9V15C19 17.828 19 19.243 18.121 20.121C17.243 21 15.828 21 13 21H11C8.172 21 6.757 21 5.879 20.121C5 19.243 5 17.828 5 15V9Z"/><path d="M11 18H13"/></svg>';
            }

            function loadDevices() {
                fetch('/api/me').then(function(r) { return r.json(); }).then(function(data) {
                    var btn = document.getElementById('devices-btn');
                    var dotsEl = document.getElementById('device-dots');
                    var list = document.getElementById('devices-list');
                    var panel = document.getElementById('devices-panel');
                    var logoutBtn = document.getElementById('logout-btn');
                    if (!btn || !dotsEl || !list || !panel) return;

                    // Dots indicator
                    var dots = '';
                    for (var i = 1; i <= data.maxDevices; i++) {
                        var dev = data.devices && data.devices.find(function(d) { return d.index === i; });
                        if (dev && dev.isCurrent) {
                            dots += '<span class="dot dot-you" title="You"></span>';
                        } else if (dev) {
                            dots += '<span class="dot dot-active" title="Connected"></span>';
                        } else {
                            dots += '<span class="dot dot-empty" title="Open slot"></span>';
                        }
                    }
                    dotsEl.innerHTML = dots;
                    btn.style.display = 'flex';

                    // Device list
                    var html = '';
                    for (var j = 1; j <= data.maxDevices; j++) {
                        var d = data.devices && data.devices.find(function(x) { return x.index === j; });
                        if (d && d.isCurrent) {
                            html += '<li class="device-item device-you">'
                                + '<span class="device-status-dot dot-you"></span>'
                                + '<span class="device-icon">' + deviceIcon(d.ua) + '</span>'
                                + '<span class="device-name">' + deviceName(d.ua) + '</span>'
                                + '<span class="device-tag">you</span>'
                                + '<button class="kick-btn kick-self" data-devname="' + deviceName(d.ua) + '">Log out</button>'
                                + '</li>';
                        } else if (d) {
                            html += '<li class="device-item device-taken">'
                                + '<span class="device-status-dot dot-active"></span>'
                                + '<span class="device-icon">' + deviceIcon(d.ua) + '</span>'
                                + '<span class="device-name">' + deviceName(d.ua) + '</span>'
                                + '<button class="kick-btn" data-idx="' + d.index + '" data-devname="' + deviceName(d.ua) + '">Log out</button>'
                                + '</li>';
                        } else {
                            html += '<li class="device-item device-open">'
                                + '<span class="device-status-dot dot-empty"></span>'
                                + '<span class="device-name open-slot">Open slot</span>'
                                + '</li>';
                        }
                    }
                    list.innerHTML = html;

                    // Custom modal helpers
                    function showSignoutModal(devName, isSelf, onConfirm) {
                        var modal = document.getElementById('signout-modal');
                        var titleEl = document.getElementById('signout-modal-title');
                        var descEl = document.getElementById('signout-modal-desc');
                        var confirmBtn = document.getElementById('signout-confirm');
                        var cancelBtn = document.getElementById('signout-cancel');
                        if (!modal || !confirmBtn || !cancelBtn) { onConfirm(); return; }
                        if (titleEl) titleEl.textContent = isSelf ? 'Sign out this device?' : 'Remove ' + devName + '?';
                        if (descEl) descEl.textContent = isSelf ? 'You\'ll need your access key to log back in.' : 'This device will be signed out and its slot freed.';
                        modal.style.display = 'flex';
                        function cleanup() {
                            modal.style.display = 'none';
                            confirmBtn.replaceWith(confirmBtn.cloneNode(true));
                            cancelBtn.replaceWith(cancelBtn.cloneNode(true));
                        }
                        document.getElementById('signout-confirm').addEventListener('click', function() { cleanup(); onConfirm(); }, { once: true });
                        document.getElementById('signout-cancel').addEventListener('click', function() { cleanup(); }, { once: true });
                        modal.addEventListener('click', function(e) { if (e.target === modal) cleanup(); }, { once: true });
                    }

                    // Self logout buttons
                    list.querySelectorAll('.kick-self').forEach(function(b) {
                        b.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var devName = b.getAttribute('data-devname') || 'this device';
                            showSignoutModal(devName, true, function() {
                                fetch('/api/logout', { method: 'POST' }).then(function() {
                                    window.location.href = '/login';
                                });
                            });
                        });
                    });

                    // Kick other device buttons
                    list.querySelectorAll('.kick-btn:not(.kick-self)').forEach(function(b) {
                        b.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var idx = parseInt(b.getAttribute('data-idx'));
                            var devName = b.getAttribute('data-devname') || 'Device ' + idx;
                            showSignoutModal(devName, false, function() {
                                b.textContent = '...';
                                b.disabled = true;
                                fetch('/api/kick-device', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ deviceIndex: idx })
                                }).then(function() { loadDevices(); }).catch(function() { b.textContent = 'Remove'; b.disabled = false; });
                            });
                        });
                    });

                    var open = false;
                    btn.onclick = null;
                    btn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        open = !open;
                        panel.style.display = open ? 'block' : 'none';
                    });
                    document.addEventListener('click', function() {
                        if (open) { open = false; panel.style.display = 'none'; }
                    });
                    panel.addEventListener('click', function(e) { e.stopPropagation(); });
                }).catch(function() {});
            }

            loadDevices();

            // Panic key: backslash → redirect to safe page
            document.addEventListener('keydown', function(e) {
                if (e.key === '\\' || e.key === 'Backslash') {
                    window.location.href = 'https://classroom.google.com';
                }
            });
        })();
    </script>
    <script src="../scripts/index.ts"></script>
    <script src="../scripts/global.ts"></script>
</Layout>

<style>
    #home-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-bottom: 100px;
    }

    #home-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        width: 100%;
        max-width: 680px;
        padding: 0 20px;
    }

    #main-title {
        font-size: clamp(3.5rem, 10vw, 6.5rem);
        font-family: bold;
        color: #fff;
        margin: 0 0 0.5rem 0;
        line-height: 1;
        letter-spacing: -0.02em;
        text-align: center;
    }

    #tagline {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.45);
        font-family: medium;
        margin: 0 0 2.2rem 0;
        text-align: center;
        letter-spacing: 0.01em;
    }

    #search-wrap {
        width: 100%;
        background: rgba(255,255,255,0.07);
        border-radius: 50px;
        padding: 14px 20px;
        margin-bottom: 1rem;
    }

    #quick-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        width: 100%;
        margin-bottom: 0;
    }

    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        min-width: 80px;
        max-width: 106px;
        height: 72px;
        border-radius: 14px;
        padding: 10px 6px;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.05);
        color: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        gap: 5px;
    }

    .quick-link:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.15);
        transform: translateY(-2px);
    }

    .quick-link svg {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
    }

    .ql-img {
        width: 26px;
        height: 26px;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 5px;
    }

    .quick-link span {
        font-size: 0.72rem;
        font-family: medium;
        color: rgba(255,255,255,0.7);
    }

    #search-form {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    #search-icon {
        color: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    #search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-size: 1rem;
        font-family: medium;
    }

    #search-input::placeholder {
        color: rgba(255,255,255,0.3);
    }

    #suggestions {
        display: none;
        flex-direction: column;
        margin-top: 10px;
        gap: 2px;
    }

    #suggestions.open {
        display: flex;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 6px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        font-family: medium;
        border: none;
        background: transparent;
        text-align: left;
        width: 100%;
    }

    .suggestion-item:hover,
    .suggestion-item.active {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

    .suggestion-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .suggestion-label {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .suggestion-hint {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    #stats-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.4);
        font-family: medium;
        margin-bottom: 1.4rem;
    }

    #stats-row #online-count {
        color: #fff;
        font-family: bold;
    }

    #stats-row #visits-count {
        color: #fff;
        font-family: bold;
    }

    .stat-dot {
        opacity: 0.3;
    }

    #discord-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    #discord-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        margin: 0;
        text-transform: uppercase;
    }

    #discord-link {
        display: flex;
        align-items: center;
        gap: 7px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        font-family: medium;
        padding: 6px 14px;
        border-radius: 100px;
        transition: color 0.2s, background 0.2s;
    }

    #discord-link:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
    }

    /* Devices panel */
    #devices-panel {
        position: fixed;
        bottom: 90px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(14,14,20,0.97);
        backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 18px 18px 14px;
        min-width: 260px;
        z-index: 300;
        box-shadow: 0 12px 50px rgba(0,0,0,0.6);
        color: #fff;
    }

    .devices-panel-title {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.3);
        font-family: medium;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0 0 14px 0;
    }

    #devices-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .device-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-family: medium;
        padding: 9px 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
        color: #fff;
        min-width: 0;
        cursor: default;
        transition: background 0.15s;
    }

    .device-you {
        background: rgba(255,255,255,0.07);
    }

    .device-taken:hover {
        background: rgba(255,255,255,0.06);
