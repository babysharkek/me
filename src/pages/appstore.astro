---
import Layout from "../Layouts/Layout.astro";
---

<Layout title="App Store">
    <main id="as-page">

        <!-- ── Header ── -->
        <header id="as-header">
            <div id="as-header-glow"></div>
            <div id="as-header-left">
                <svg id="as-logo-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                <div>
                    <h1 id="as-title">App Store</h1>
                    <p id="as-subtitle">Discover & download your favourite apps</p>
                </div>
            </div>
            <div id="as-header-right">
                <button id="as-add-custom" aria-label="Add custom app">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <div id="as-search-wrap">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M21 21L15.0001 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input id="as-search" type="text" placeholder="Search apps…" autocomplete="off"/>
                </div>
            </div>
        </header>

        <!-- ── Featured Carousel ── -->
        <section id="as-featured-section">
            <h2 class="as-section-label">Featured</h2>
            <div id="as-carousel">
                <div id="as-carousel-viewport">
                    <div id="as-carousel-track"></div>
                </div>
                <button id="as-prev" class="as-arrow" aria-label="Previous">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <button id="as-next" class="as-arrow" aria-label="Next">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                        <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <div id="as-carousel-dots"></div>
            </div>
        </section>

        <!-- ── All Apps Grid ── -->
        <section id="as-store-section">
            <h2 class="as-section-label">All Apps</h2>
            <div id="as-grid"></div>
        </section>

        <!-- ── Custom App Modal ── -->
        <div id="as-modal-overlay" class="hidden">
            <div id="as-modal">
                <div id="as-modal-header">
                    <h2 id="as-modal-title">Create Custom App</h2>
                    <button id="as-modal-close" aria-label="Close modal">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
                <div id="as-modal-body">
                    <div class="as-form-group">
                        <label for="as-custom-name">App Name</label>
                        <input type="text" id="as-custom-name" placeholder="e.g. My Website" autocomplete="off"/>
                    </div>
                    <div class="as-form-group">
                        <label for="as-custom-url">App URL</label>
                        <input type="text" id="as-custom-url" placeholder="https://example.com" autocomplete="off"/>
                    </div>
                    <div class="as-form-group">
                        <label for="as-custom-icon">App Icon URL (Optional)</label>
                        <input type="text" id="as-custom-icon" placeholder="https://example.com/icon.png" autocomplete="off"/>
                    </div>
                </div>
                <div id="as-modal-footer">
                    <button id="as-install-custom" class="as-btn-primary">Install App</button>
                </div>
            </div>
        </div>

        <!-- ── Toast ── -->
        <div id="as-toast"></div>

    </main>
    <script src="../scripts/appstore.ts"></script>
</Layout>
